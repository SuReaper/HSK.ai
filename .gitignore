# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
nul

# foundry
/out/
/cache/
broadcast/
deployments/
/lib/
contracts/
foundry.toml

# docs/plans (internal dev notes)
docs/

# local SQLite database (auto-created by ensureDb on first run)
sqlite.db
sqlite.db-wal
sqlite.db-shm

# local agent/tooling configs (not part of the project)
.agents/
.kilo/
skills/
skills-lock.json
builtin/
CLAUDE.md
REASONING.md
AGENTS.md

# logs
*.log
