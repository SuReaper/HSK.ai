# ═══════════════════════════════════════════════════════════════════════
# HSK.ai Environment Configuration
# Copy this file to .env.local and fill in the values.
#   cp .env.example .env.local
# ═══════════════════════════════════════════════════════════════════════

# ── WalletConnect / Reown AppKit ───────────────────────────────────────
# Get a project id at https://cloud.reown.com (free).
NEXT_PUBLIC_WC_PROJECT_ID=fc709d754f623dac436c80606d1709c8

# ── HSP Verifiable Settlement (server-side) ────────────────────────────
# Sandbox (testnet) coordinator hub.
HSP_COORDINATOR_URL=https://hsp-hackathon.hashkeymerchant.com

# HSP facilitator endpoint (for x402 v2 scenarios).
HSP_FACILITATOR_URL=https://hsp-hackathon.hashkeymerchant.com/facilitator

# Your team's HSP write key (Bearer token). Register at the coordinator /register.
# Without it the app runs in read-only mode (observe + verify, no settle).
HSP_API_KEY=

# HSP chain name. Defaults to "hashkey-testnet".
HSP_CHAIN=hashkey-testnet

# Pinned HSP adapter contract address on the settlement chain.
HSP_PINNED_ADAPTER_ADDRESS=0x467AaF355DF243379B961Ce00abBae20c1e25012

# ── Smart Contract Addresses (public, client-visible) ──────────────────
# Intent anchor contract — records payment intent hashes on-chain.
NEXT_PUBLIC_INTENT_ANCHOR_ADDRESS_TESTNET=0xB558d9ceEe9Fe4024c6Be650DD3d3d7D9e22E9bA
NEXT_PUBLIC_INTENT_ANCHOR_ADDRESS_MAINNET=0xB558d9ceEe9Fe4024c6Be650DD3d3d7D9e22E9bA

# Recurring payment contracts.
NEXT_PUBLIC_RECURRING_ADDRESS_TESTNET=0x1b3be9Ce060F75c8525f7Cad68db50BB3791620a
NEXT_PUBLIC_RECURRING_ADDRESS_MAINNET=0x1b3be9Ce060F75c8525f7Cad68db50BB3791620a

# ── CCIP Router (optional, has sensible defaults) ──────────────────────
# Defaults to the official Sepolia CCIP Router. Override only if needed.
# NEXT_PUBLIC_CCIP_ROUTER_11155111=0x0BF3dE8c5D3e8A2B34D2BEeB17ABfCeBaf363A59
